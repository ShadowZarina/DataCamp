# PROMPT ENGINEERING BEST PRACTICES (FORMATTING)
client = OpenAI(api_key="OPENAI_API_TOKEN")

instructions = """Infer the language and the number of sentences of the given delimited text; then if the text contains more than one sentence, generate a suitable text for it, otherwise, write 'N/A' for the title."""

output_format = """
        - Text: <the text>
        - Language: <the text language>
        - Title: <the generated title>"""

prompt = instructions + output_format + f"```{text}```"
response = get_response(prompt)
print(response)

